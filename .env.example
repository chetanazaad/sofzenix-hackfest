# ── Sofzenix HackFest Environment Configuration ──────────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is gitignored and must NEVER be shared.

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string

# ── MySQL — Client's Local Database ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=sofzenix_hackfest

# ── Admin Credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@2026

# ── Google OAuth (optional — get from Google Cloud Console) ───────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# ── Payment Gateways ──────────────────────────────────────────────────────────
# Set DEV_MODE=false only when ready to go live with real payouts
DEV_MODE=true

RAZORPAYX_KEY_ID=
RAZORPAYX_KEY_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=

PHONEPE_MERCHANT_ID=
PHONEPE_API_KEY=

# ── CORS — Hostinger Domain ───────────────────────────────────────────────────
# Set this to your Hostinger domain when frontend is deployed there
ALLOWED_ORIGIN=http://localhost:5500
