# ──────────────── Sofzenix HackFest .env ────────────────────────
# Copy this file to just ".env" and fill in your values.
SECRET_KEY=sofzenix-hackfest-change-this-key-2026

# MySQL — Your Local Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=sofzenix_hackfest

# Admin Login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@2026

# Payment Mode — keep TRUE until you're ready for real payouts
DEV_MODE=true

# Google OAuth (optional — fill from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# RazorpayX (fill when DEV_MODE=false)
RAZORPAYX_KEY_ID=
RAZORPAYX_KEY_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=

# PhonePe (fill when DEV_MODE=false)
PHONEPE_MERCHANT_ID=
PHONEPE_API_KEY=

# CORS — set to your Hostinger domain for production
ALLOWED_ORIGIN=http://localhost:5500
